# Credenciais do Supabase (Fase 2 — sync na nuvem).
# Copie para .env.local e preencha com os dados do seu projeto:
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# IA (Fase A) — variáveis SERVER-SIDE, configurar na Vercel (NÃO no client, sem VITE_).
# A function /api/ai usa isto; a chave nunca vai pro navegador.
#   XAI_API_KEY  = sua chave da API xAI (obrigatória p/ uso real)
#   XAI_MODEL    = modelo (padrão "grok-4-fast"; ajuste pro que você usa)
#   AI_MOCK=1    = devolve resultado FALSO (heurístico) sem chamar a xAI — testar sem gastar créditos
XAI_API_KEY=
XAI_MODEL=
# AI_MOCK=1
